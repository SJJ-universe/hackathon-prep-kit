# =========================================================================
#  .env.example — 복사해서 .env 로 만들고 키를 채우세요.  (.env 는 커밋 금지)
#    cp .env.example .env        (PowerShell:  Copy-Item .env.example .env)
# =========================================================================

# data.go.kr 일반 인증키 — 모든 data.go.kr 데이터셋이 공유.
# 권장: "Decoding 키"(+,/,= 가 그대로 보이는 원문)를 넣으세요. 프록시가 1회만 인코딩합니다.
DATA_GO_KR_KEY=

# 만약 "Encoding 키"(%2B 처럼 이미 인코딩된 형태)를 넣었다면 이중인코딩을 막기 위해 true:
# DATA_GO_KR_KEY_ENCODED=true

# safetydata.go.kr 키 (재난문자/민방위대피소). 승인 심사 필요 → 대회 전 미리 발급.
# 주의: 파라미터명이 serviceKey(대문자 K)여야 동작.
SAFETYDATA_KEY=
# SAFETYDATA_KEY_ENCODED=true

# Kakao REST 키 (주소→좌표 지오코딩). developers.kakao.com 에서 즉시 발급.
# REST 키여야 함(JS키/Admin키 아님). 헤더 Authorization: KakaoAK <키>.
KAKAO_REST_KEY=
